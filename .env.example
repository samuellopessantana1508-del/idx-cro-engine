# IDX CRO Engine - variaveis locais do painel
#
# Copie este arquivo para web/.env.local no ambiente do frontend.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY

# Base usada para montar links copiados no painel.
# Se usar a Edge Function direto:
VITE_PUBLIC_REDIRECT_BASE=https://SEU-PROJETO.supabase.co
VITE_REDIRECT_PATH_PREFIX=/functions/v1/go

# Se no futuro usar dominio curto com rewrite:
# VITE_PUBLIC_REDIRECT_BASE=https://go.seudominio.com
# VITE_REDIRECT_PATH_PREFIX=

