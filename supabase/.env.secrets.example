# IDX CRO Engine - secrets das Edge Functions
#
# Copie os valores e rode com:
# supabase secrets set NOME=VALOR

# URL publica do painel web.
APP_URL=https://app.seudominio.com

# Emails que podem criar clientes no banco unico da IDX sem SQL inicial.
# Use virgula para mais de um email. Ex: gestor@idx.com,admin@idx.com
PLATFORM_OWNER_EMAILS=seu-email@empresa.com

# Padrao seguro: apenas gestores IDX criam tenants/clientes.
# Para um teste local aberto, use false. Em producao, mantenha true ou remova.
REQUIRE_PLATFORM_ADMIN_FOR_TENANT_CREATE=true

# Para onde redirecionar se um Smart Link quebrar ou for invalido.
FALLBACK_URL=https://wa.me/5564999999999

# Versao Meta Graph API usada pelas Edge Functions.
META_GRAPH_VERSION=v25.0

# Meta App - modo "Conectar Facebook".
# Crie a App em https://developers.facebook.com/apps/
META_APP_ID=COLE_AQUI_O_APP_ID
META_APP_SECRET=COLE_AQUI_O_APP_SECRET

# Deve ser EXATAMENTE a mesma URL cadastrada em Valid OAuth Redirect URIs.
# No fluxo atual, use a pagina publica do painel que encaminha para meta-oauth.
META_REDIRECT_URI=https://SEU-DOMINIO.com/meta-oauth-callback.html

# Obrigatorio quando a app usa Facebook Login for Business.
# Meta Developers > Facebook Login for Business > Configurations > Configuration ID.
META_LOGIN_CONFIG_ID=COLE_AQUI_O_CONFIGURATION_ID
